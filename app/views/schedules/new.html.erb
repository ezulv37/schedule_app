<div class="new_page">
  <h2 class="pageTitle_text">予定の新規追加</h2>

  <% if flash[:notice] %>
    <p class="notice"><%= flash[:notice] %></p>
  <% end %>
  <%= render "shared/error", obj: @schedule %>

  <%= form_with model: @schedule do |f| %>
    <div class="formFrame">
      <div class="input_item">
        <p class="form_label"><%= f.label :title ,"タイトル", class: "Form__label--required" %></p>
        <div><%= f.text_field :title, class: "form-control form-cntl_1" %></div>
      </div>

      <div class="date_form">
        <div class="input_item start_end_date">
          <p  class="form_label"><%= f.label :start_date ,"開始日", class: "Form__label--required" %></p>
          <div><%= f.date_field :start_date, value: f.object.start_date&.strftime('%Y/%m/%d'), class: "form-control form-cntl_1" %></div>
        </div>

        <div class="input_item start_end_date">
          <p class="form_label"><%= f.label :end_date ,"終了日", class: "Form__label--required" %></p>
          <div><%= f.date_field :end_date, value: f.object.end_date&.strftime('%Y/%m/%d'), class: "form-control form-cntl_1" %></div>
        </div>
      </div>

      <div class="input_item allDay_check">
        <div><%= f.check_box :all_day, class:"checkbox" %></div>
        <p><%= f.label :all_day ,"終日の場合はチェックを入れます", class: "allday_Text"%></p>
      </div>

      <div class="input_item">
        <p class="form_label"><%= f.label :memo ,"スケジュールメモ" %></p>
        <div><%= f.text_area :memo, class: "form-control form-cntl_2" %></div>
      </div>

      <div class="new_edit_btn">
          <p class="cancel"><%= link_to "キャンセル", :schedules, class:"btn_c hover-darken" %></p>
          <p><%= f.submit "保存", class:"btn_b hover-darken"%></p>
      </div>
    </div>
  <% end %>
</div>
